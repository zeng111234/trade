# ===========================
# QDII基金每日分配器 - 配置模板
# ===========================
# 复制此文件为 .env，然后填入你的真实配置
# cp .env.example .env

# ---------- 邮件配置 (SMTP) ----------
# QQ邮箱示例：
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
# 163邮箱示例：
#   SMTP_HOST=smtp.163.com
#   SMTP_PORT=465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code
MAIL_TO=recipient@example.com

# ---------- LLM配置 (可选) ----------
# mimo-v2.5-pro / DeepSeek / 任何 OpenAI 兼容 API
# 如果不配置，AI分析功能会自动跳过
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.example.com/v1/chat/completions
LLM_MODEL=mimo-v2.5-pro